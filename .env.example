# ─────────────────────────────────────────────────────────────
# opa-api-whatsapp (Next.js) — variáveis de ambiente
# Copie para .env.local e preencha. NUNCA comite o .env real.
# ─────────────────────────────────────────────────────────────

# --- Supabase ---
# URL do projeto (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service Role key (Settings > API). Server-side apenas — NUNCA exponha no client.
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# --- Segurança da nossa API ---
# Token que protege a API/Interface admin. Gere: openssl rand -hex 32
APP_ADMIN_TOKEN=troque-por-um-token-forte

# Chave (base64 de 32 bytes) para criptografar os tokens OPA no banco (AES-256-GCM).
# Gere: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=cole-aqui-a-chave-base64

# --- Cache ---
CACHE_TTL_SECONDS=60

# --- OPA Suite (defaults; cada cliente sobrescreve base_url/token) ---
# Tamanho de página da paginação skip/limit
OPA_PAGE_SIZE=500
# Timeout (ms) das chamadas à OPA
OPA_TIMEOUT_MS=30000
# Janela incremental (dias) p/ dataInicialAbertura nos atendimentos
DEFAULT_LOOKBACK_DAYS=30
